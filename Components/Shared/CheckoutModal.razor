@implements IDisposable
@inject CartState Cart

<div class="fixed inset-0 bg-black/60 z-50 backdrop-blur-sm flex items-end sm:items-center justify-center p-0 sm:p-4">
    <div class="bg-white w-full sm:max-w-lg rounded-t-3xl sm:rounded-2xl shadow-2xl max-h-[90vh] flex flex-col">
        <div class="flex items-center justify-between px-6 py-4 border-b border-stone-100">
            <div>
                <h2 class="text-lg font-bold text-stone-900">Complete Your Order</h2>
                <p class="text-sm text-stone-500">@Cart.Lines.Count item@(Cart.Lines.Count != 1 ? "s" : "") · $@Cart.Total.ToString("0.00")</p>
            </div>
            <button @onclick="OnClose"
                    class="w-8 h-8 flex items-center justify-center text-stone-400 hover:text-stone-600 hover:bg-stone-100 rounded-xl transition-colors">
                <Icon Name="x" Class="w-5 h-5" />
            </button>
        </div>

        <div class="overflow-y-auto flex-1">
            <div class="px-6 py-4 bg-stone-50 border-b border-stone-100">
                <p class="text-xs font-semibold text-stone-400 uppercase tracking-wide mb-2">Order Summary</p>
                <div class="space-y-1.5">
                    @foreach (var line in Cart.Lines)
                    {
                        <div class="flex items-center justify-between text-sm">
                            <span class="text-stone-700">@line.Item.Name <span class="text-stone-400">×@line.Quantity</span></span>
                            <span class="font-medium text-stone-900">$@line.Subtotal.ToString("0.00")</span>
                        </div>
                    }
                </div>
                <div class="flex items-center justify-between mt-3 pt-3 border-t border-stone-200 font-bold text-stone-900">
                    <span>Total</span>
                    <span>$@Cart.Total.ToString("0.00")</span>
                </div>
            </div>

            <form @onsubmit="HandleSubmit" @onsubmit:preventDefault class="px-6 py-4 space-y-4">
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-1.5">
                        Your Name <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                        <Icon Name="user" Class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" />
                        <input type="text" @bind="_name" @bind:event="oninput" placeholder="Juan dela Cruz"
                               class="@NameInputClass" />
                    </div>
                    @if (_nameError)
                    {
                        <p class="text-red-500 text-xs mt-1">Name is required</p>
                    }
                </div>

                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-1.5">Email (optional)</label>
                    <div class="relative">
                        <Icon Name="mail" Class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" />
                        <input type="email" @bind="_email" @bind:event="oninput" placeholder="juan@email.com"
                               class="w-full pl-10 pr-4 py-2.5 border border-stone-200 rounded-xl text-sm outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-colors" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-1.5">Table Number (optional)</label>
                    <div class="relative">
                        <Icon Name="hash" Class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-stone-400" />
                        <input type="text" @bind="_table" @bind:event="oninput" placeholder="e.g. Table 5"
                               class="w-full pl-10 pr-4 py-2.5 border border-stone-200 rounded-xl text-sm outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-colors" />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-1.5">Special Requests (optional)</label>
                    <div class="relative">
                        <Icon Name="sticky-note" Class="absolute left-3 top-3 w-4 h-4 text-stone-400" />
                        <textarea @bind="_notes" @bind:event="oninput" placeholder="Allergies, dietary requirements, etc." rows="3"
                                  class="w-full pl-10 pr-4 py-2.5 border border-stone-200 rounded-xl text-sm outline-none focus:border-amber-400 focus:ring-2 focus:ring-amber-100 transition-colors resize-none"></textarea>
                    </div>
                </div>

                <button type="submit" disabled="@_loading"
                        class="w-full bg-amber-500 hover:bg-amber-600 disabled:opacity-60 text-white py-3.5 rounded-xl font-semibold text-base transition-all duration-200 shadow-md hover:shadow-lg flex items-center justify-center gap-2">
                    @if (_loading)
                    {
                        <Icon Name="loader-circle" Class="w-4 h-4 animate-spin" />
                        <span>Placing Order...</span>
                    }
                    else
                    {
                        <span>Confirm Order · $@Cart.Total.ToString("0.00")</span>
                    }
                </button>
            </form>
        </div>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<CheckoutDetails> OnSubmit { get; set; }

    private string _name = "";
    private string _email = "";
    private string _table = "";
    private string _notes = "";
    private bool _nameError;
    private bool _loading;

    private string NameInputClass =>
        "w-full pl-10 pr-4 py-2.5 border rounded-xl text-sm outline-none transition-colors " +
        (_nameError
            ? "border-red-300 bg-red-50"
            : "border-stone-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-100");

    private async Task HandleSubmit()
    {
        _nameError = string.IsNullOrWhiteSpace(_name);
        if (_nameError) return;

        _loading = true;
        try
        {
            await OnSubmit.InvokeAsync(new CheckoutDetails
            {
                Name = _name.Trim(),
                Email = _email.Trim(),
                Table = _table.Trim(),
                Notes = _notes.Trim()
            });
        }
        finally
        {
            _loading = false;
        }
    }

    protected override void OnInitialized() => Cart.OnChange += StateHasChanged;

    public void Dispose() => Cart.OnChange -= StateHasChanged;
}
