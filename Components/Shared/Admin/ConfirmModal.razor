<div class="fixed inset-0 bg-black/60 z-50 backdrop-blur-sm flex items-center justify-center p-4">
    <div class="bg-white w-full max-w-sm rounded-2xl shadow-2xl p-6">
        <h2 class="text-lg font-bold text-stone-900 mb-1">@Title</h2>
        <p class="text-sm text-stone-500 mb-6">@Message</p>
        <div class="flex items-center justify-end gap-2">
            <button @onclick="OnCancel"
                    class="px-4 py-2 rounded-xl text-sm font-medium text-stone-600 hover:bg-stone-100 transition-colors">
                Cancel
            </button>
            <button @onclick="OnConfirm"
                    class="px-4 py-2 rounded-xl text-sm font-semibold text-white bg-red-500 hover:bg-red-600 transition-colors shadow-sm">
                @ConfirmLabel
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Are you sure?";
    [Parameter] public string Message { get; set; } = "This action cannot be undone.";
    [Parameter] public string ConfirmLabel { get; set; } = "Delete";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
