<div class="bg-white rounded-2xl border border-stone-100 shadow-sm p-5">
    <div class="flex items-center justify-between">
        <div>
            <p class="text-stone-500 text-sm">@Label</p>
            <p class="text-2xl font-bold text-stone-900 mt-1">@Value</p>
        </div>
        <div class="w-10 h-10 bg-amber-100 text-amber-600 rounded-xl flex items-center justify-center">
            <Icon Name="@Icon" Class="w-5 h-5" />
        </div>
    </div>
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
}
