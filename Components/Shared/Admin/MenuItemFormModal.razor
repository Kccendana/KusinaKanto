<div class="fixed inset-0 bg-black/60 z-50 backdrop-blur-sm flex items-end sm:items-center justify-center p-0 sm:p-4">
    <div class="bg-white w-full sm:max-w-lg rounded-t-3xl sm:rounded-2xl shadow-2xl max-h-[92vh] flex flex-col">
        <div class="flex items-center justify-between px-6 py-4 border-b border-stone-100">
            <h2 class="text-lg font-bold text-stone-900">@(IsNew ? "Add Menu Item" : "Edit Menu Item")</h2>
            <button @onclick="OnCancel"
                    class="w-8 h-8 flex items-center justify-center text-stone-400 hover:text-stone-600 hover:bg-stone-100 rounded-xl transition-colors">
                <Icon Name="x" Class="w-5 h-5" />
            </button>
        </div>

        <form @onsubmit="Submit" @onsubmit:preventDefault class="overflow-y-auto px-6 py-4 space-y-4">
            <div>
                <label class="block text-sm font-medium text-stone-700 mb-1.5">Name <span class="text-red-500">*</span></label>
                <input type="text" @bind="Item.Name" @bind:event="oninput" placeholder="e.g. Chicken Adobo"
                       class="@InputClass(_nameError)" />
                @if (_nameError) { <p class="text-red-500 text-xs mt-1">Name is required</p> }
            </div>

            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-1.5">Category</label>
                    <select @bind="Item.CategoryId" class="@InputClass(false)">
                        @foreach (var c in Categories)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-stone-700 mb-1.5">Price ($)</label>
                    <input type="number" step="0.01" min="0" @bind="Item.Price" class="@InputClass(false)" />
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-stone-700 mb-1.5">Description</label>
                <textarea @bind="Item.Description" rows="2" placeholder="Short description"
                          class="@InputClass(false) resize-none"></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-stone-700 mb-1.5">Image URL</label>
                <input type="text" @bind="Item.ImageUrl" placeholder="https://..." class="@InputClass(false)" />
            </div>

            <div class="flex flex-wrap gap-4 pt-1">
                <label class="flex items-center gap-2 text-sm text-stone-700">
                    <input type="checkbox" @bind="Item.IsBestseller" class="accent-amber-500 w-4 h-4" /> Best seller
                </label>
                <label class="flex items-center gap-2 text-sm text-stone-700">
                    <input type="checkbox" @bind="Item.IsSpicy" class="accent-red-500 w-4 h-4" /> Spicy
                </label>
                <label class="flex items-center gap-2 text-sm text-stone-700">
                    <input type="checkbox" @bind="Item.IsAvailable" class="accent-amber-500 w-4 h-4" /> Available
                </label>
            </div>

            <div class="flex items-center justify-end gap-2 pt-2">
                <button type="button" @onclick="OnCancel"
                        class="px-4 py-2 rounded-xl text-sm font-medium text-stone-600 hover:bg-stone-100 transition-colors">
                    Cancel
                </button>
                <button type="submit"
                        class="px-5 py-2 rounded-xl text-sm font-semibold text-white bg-amber-500 hover:bg-amber-600 transition-colors shadow-sm">
                    @(IsNew ? "Add Item" : "Save Changes")
                </button>
            </div>
        </form>
    </div>
</div>

@code {
    [Parameter] public MenuItem Item { get; set; } = default!;
    [Parameter] public IReadOnlyList<MenuCategory> Categories { get; set; } = new List<MenuCategory>();
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public EventCallback<MenuItem> OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool _nameError;

    private static string InputClass(bool error) =>
        "w-full px-3 py-2.5 border rounded-xl text-sm outline-none transition-colors " +
        (error ? "border-red-300 bg-red-50"
               : "border-stone-200 focus:border-amber-400 focus:ring-2 focus:ring-amber-100");

    private async Task Submit()
    {
        _nameError = string.IsNullOrWhiteSpace(Item.Name);
        if (_nameError) return;
        await OnSave.InvokeAsync(Item);
    }
}
