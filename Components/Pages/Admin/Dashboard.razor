@page "/admin"
@layout AdminLayout
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.EntityFrameworkCore
@using KusinaKanto.Data
@inject IMenuAdminService MenuAdmin
@inject IStaffService StaffService
@inject KusinaKantoDbContext Db

<PageTitle>Dashboard · KusinaKanto Admin</PageTitle>

<h1 class="text-2xl font-bold text-stone-900 mb-1">Dashboard</h1>
<p class="text-stone-500 mb-6">Overview of your restaurant.</p>

<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <StatCard Label="Menu Items" Value="@_itemCount.ToString()" Icon="utensils-crossed" />
    <StatCard Label="Categories" Value="@_categoryCount.ToString()" Icon="layout-dashboard" />
    <StatCard Label="Orders" Value="@_orderCount.ToString()" Icon="shopping-bag" />
    <StatCard Label="Active Staff" Value="@($"{_activeStaff}/{_staffCount}")" Icon="users" />
</div>

<div class="bg-white rounded-2xl border border-stone-100 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-stone-100">
        <h2 class="font-bold text-stone-900">Recent Orders</h2>
    </div>
    @if (_recentOrders.Count == 0)
    {
        <div class="px-5 py-10 text-center text-stone-400">No orders yet.</div>
    }
    else
    {
        <table class="w-full text-sm">
            <thead class="text-left text-stone-400 uppercase text-xs tracking-wide">
                <tr class="border-b border-stone-100">
                    <th class="px-5 py-3 font-semibold">Customer</th>
                    <th class="px-5 py-3 font-semibold">Placed</th>
                    <th class="px-5 py-3 font-semibold">Status</th>
                    <th class="px-5 py-3 font-semibold text-right">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in _recentOrders)
                {
                    <tr class="border-b border-stone-50 last:border-0">
                        <td class="px-5 py-3 font-medium text-stone-900">@(o.OrderType == OrderType.DineIn
        ? $"Dine-In - T{o.TableNumber}"
        : $"Take-Out - #{o.Id:D3}")</td>
                        <td class="px-5 py-3 text-stone-500">@o.CreatedAt.ToString("MMM d, h:mm tt")</td>
                        <td class="px-5 py-3">
                            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">@o.Status</span>
                        </td>
                        <td class="px-5 py-3 text-right font-semibold text-stone-900">$@o.TotalAmount.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    private int _itemCount, _categoryCount, _orderCount, _staffCount, _activeStaff;
    private List<Order> _recentOrders = new();

    protected override async Task OnInitializedAsync()
    {
        _itemCount = (await MenuAdmin.GetItemsAsync()).Count;
        _categoryCount = (await MenuAdmin.GetCategoriesAsync()).Count;

        var staff = await StaffService.GetAllAsync();
        _staffCount = staff.Count;
        _activeStaff = staff.Count(s => s.IsActive);

        _orderCount = await Db.Orders.CountAsync();
        _recentOrders = await Db.Orders.AsNoTracking()
            .OrderByDescending(o => o.CreatedAt)
            .Take(5)
            .ToListAsync();
    }
}
