@page "/kitchen"
@layout MainLayout
@attribute [Authorize(Roles = "Admin, Kitchen")]

@using Microsoft.EntityFrameworkCore
@using KusinaKanto.Data
@using KusinaKanto.Models

@inject KusinaKantoDbContext Db

<PageTitle>Kitchen Display</PageTitle>
<div class="min-h-screen bg-stone-50">

<!-- Header -->
<div class="sticky top-0 z-10 bg-white border-b border-stone-200 shadow-sm">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <div>
        <h1 class="text-3xl font-bold text-stone-900">
            Kitchen Display
        </h1>
    </div>

    <div class="flex items-center gap-4">

        <div class="bg-amber-100 text-amber-800 px-4 py-2 rounded-xl font-semibold">
            @_orders.Count Active Orders
        </div>

        <form method="post" action="/auth/logout" data-enhance="false">
            <button type="submit"
                    class="bg-stone-900 hover:bg-stone-800 text-white px-4 py-2 rounded-xl font-medium transition flex items-center gap-2">
                <Icon Name="log-out" Class="w-4 h-4" />
                <span>Log out</span>
            </button>
        </form>

    </div>
</div>
</div>

<!-- Content -->
<div class="max-w-7xl mx-auto p-6">

    @if (_orders.Count == 0)
    {
        <div class="bg-white rounded-3xl p-16 text-center shadow-sm border border-stone-100">
            <h2 class="text-2xl font-bold text-stone-700">
                No Active Orders
            </h2>

            <p class="text-stone-400 mt-2">
                Waiting for new orders...
            </p>
        </div>
    }
    else
    {
        <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">

            @foreach (var order in _orders)
            {
                <div class="bg-white rounded-3xl shadow-lg border border-stone-200 overflow-hidden">

                    <!-- Card Header -->
                    <div class="bg-stone-900 text-white px-5 py-4">

                        <div class="flex justify-between items-start">

                            <div>
                                <h2 class="text-2xl font-bold">
                                    @(order.OrderType == OrderType.DineIn
                                        ? $"Dine-In- T{order.TableNumber}"
                                        : $"Take-Out #{order.Id:D3}")
                                </h2>

                                <p class="text-stone-300 text-sm mt-1">
                                    @order.CreatedAt.ToLocalTime().ToString("h:mm tt")
                                </p>
                            </div>

                            <div class="text-right">
                                <div class="text-xs uppercase text-stone-400">
                                    Waiting
                                </div>

                                <div class="text-xl font-bold text-amber-400">
                                    @GetMinutesWaiting(order.CreatedAt)m
                                </div>
                            </div>

                        </div>

                    </div>

                    <!-- Items -->
                    <div class="p-5">

                        <div class="space-y-3">

                            @foreach (var item in order.Items)
                            {
                                <div class="flex justify-between items-center">

                                    <span class="text-lg font-medium text-stone-800">
                                        @item.Name
                                    </span>

                                    <span class="px-3 py-1 font-bold text-lg">
                                         @item.Quantity
                                    </span>

                                </div>
                            }

                        </div>

                        <div class="mt-5 pt-4 border-t border-stone-200 flex justify-between items-center">
                            <span class="text-stone-500 font-medium">
                                Total
                            </span>

                            <span class="text-2xl font-bold text-stone-900">
                                $@order.TotalAmount.ToString("0.00")
                            </span>
                        </div>

                    </div>

                    <!-- Footer -->
                    <div class="p-5 pt-0">

                        <button
                            class="w-full bg-amber-500 hover:bg-amber-600 active:bg-amber-800 text-white py-4 rounded-2xl font-bold text-lg transition"
                            @onclick="() => OrderReady(order)">
                            ✓ OrderReady
                        </button>

                    </div>

                </div>
            }

        </div>
    }

</div>

</div>



@code {

    private List<Order> _orders = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        _orders = await Db.Orders
            .Include(o => o.Items)
            .Where(o => o.Status == OrderStatus.Pending || o.Status == OrderStatus.Preparing)
            .OrderBy(o => o.CreatedAt) // FIFO
            .ToListAsync();
    }

    private int GetMinutesWaiting(DateTime createdAt)
    {
        return (int)(DateTime.UtcNow - createdAt).TotalMinutes;
    }

    private async Task OrderReady(Order order)
    {
        order.Status = OrderStatus.Ready;

        await Db.SaveChangesAsync();

        _orders.Remove(order);
    }
}